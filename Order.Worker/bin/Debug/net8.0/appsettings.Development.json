{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "CosmosDb": {
    "ConnectionString": "AccountEndpoint=<your-cosmosdb-endpoint>;AccountKey=<your-cosmosdb-key>;",
    "DatabaseName": "OrderDb",
    "ContainerName": "Orders"
  },
  "EventHub": {
    "ConnectionString": "Endpoint=sb://<your-eventhub-namespace>.servicebus.windows.net/;SharedAccessKeyName=<your-shared-access-key-name>;SharedAccessKey=<your-shared-access-key>",
    "EventHubName": "order-events-hub",
    "ConsumerGroup": "$Default",
    "BlobStorageConnectionString": "DefaultEndpointsProtocol=https;AccountName=<your-storage-account-name>;AccountKey=<your-storage-account-key>;EndpointSuffix=core.windows.net",
    "BlobContainerName": "eventhub-checkpoint"
  }
}
